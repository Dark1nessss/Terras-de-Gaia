DirectoryIndex disabled

RewriteEngine On

# If the request is for a real file or directory, serve it directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Proxy all other requests to the Node.js app
# cPanel Node.js apps run on a local port — replace 3000 with your app's port
RewriteRule ^(.*)$ http://127.0.0.1:3000/$1 [P,L]

# Required for mod_proxy to work
ProxyPassReverse / http://127.0.0.1:3000/
